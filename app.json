{
  "expo": {
    "name": "Bustling",
    "slug": "errandly_app",
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/bustling.jpeg",
    "scheme": "errandlyapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android":{
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.lan24.bustling.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/bustling.jpeg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "af1941ef-b3ad-45e9-8dec-8f9257c44be7"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/181627b7-d4ec-4aff-92ff-f0a56ae610e0"
    },
    "owner": "lan24"
  }
}
